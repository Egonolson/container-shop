# ============================================================
# Container-Portal Seyfarth — Production Environment Template
# ============================================================
# WICHTIG: Diese Datei NICHT committen wenn echte Werte drin sind!
# Kopieren als .env.prod und echte Werte einsetzen.

# --- Datenbank ---
POSTGRES_USER=medusa
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=medusa-store

# --- Medusa Secrets (MUST be strong random strings in production!) ---
# Generieren mit: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_32chars_minimum
COOKIE_SECRET=CHANGE_ME_cookie_secret_32chars_minimum

# --- Medusa Backend URL (used by admin panel) ---
MEDUSA_BACKEND_URL=https://container.visionmakegpt.work

# --- CORS Settings ---
# Storefront-URL und lokale Entwicklung
STORE_CORS=https://shop.seyfarth-container.de,https://container.visionmakegpt.work
# Admin-Panel URLs
ADMIN_CORS=https://container.visionmakegpt.work,https://admin.seyfarth-container.de
# Auth-CORS (same as store + admin)
AUTH_CORS=https://shop.seyfarth-container.de,https://container.visionmakegpt.work,https://admin.seyfarth-container.de

# --- Medusa Publishable Key (from admin dashboard after first run) ---
MEDUSA_PUBLISHABLE_KEY=pk_your_key_here

# --- SMTP Email Configuration ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your-brevo-api-key
SMTP_FROM=noreply@seyfarth-container.de
SMTP_FROM_NAME=Seyfarth Container-Dienst
OPERATOR_EMAIL=info@seyfarth-container.de

# --- Storefront ---
MAIN_WEBSITE_URL=https://www.seyfarth-container.de

# --- Optional ---
# DB_SSL=true          # Wenn SSL-Verbindung zur DB nötig
# DISABLE_ADMIN=false  # Admin Panel deaktivieren (nicht empfohlen)
