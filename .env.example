# ============================================================
# Container-Portal Seyfarth — Environment Template
# ============================================================
# Kopieren als .env.dev / .env.prod und echte Werte einsetzen.
# Dateien mit echten Werten NICHT committen (.env.* ist gitignored).

# --- Runtime ---
NODE_ENV=production
IMAGE_TAG=latest

# --- Storefront / Anfrage-Konfigurator (Next.js build args) ---
SITE_URL=https://seyfarth-dev.visionmakegpt.work
MAIN_WEBSITE_URL=https://www.containerdienst-seyfarth.de

# --- Optional: SMTP für Anfrage-Benachrichtigungen ---
# Aktuell nicht im Storefront-Code verdrahtet; bei Aktivierung hier setzen.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@example.com
# SMTP_PASS=your-brevo-api-key
# SMTP_FROM=noreply@containerdienst-seyfarth.de
# SMTP_FROM_NAME=Seyfarth Container-Dienst
# OPERATOR_EMAIL=info@containerdienst-seyfarth.de
