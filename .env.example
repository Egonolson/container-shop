# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-secure-password
POSTGRES_DB=medusa-store

# Medusa Secrets
JWT_SECRET=change-me-to-random-string
COOKIE_SECRET=change-me-to-random-string

# Medusa Publishable Key (get from admin dashboard after first run)
MEDUSA_PUBLISHABLE_KEY=pk_your_key_here

# SMTP Email Configuration
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@seyfarth-container.de
SMTP_FROM_NAME=Seyfarth Container-Dienst
OPERATOR_EMAIL=info@seyfarth-container.de

# Storefront
MAIN_WEBSITE_URL=https://www.seyfarth-container.de
