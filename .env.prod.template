# ============================================================
# Seyfarth Container-Portal — PROD (hetzner-prod)
# URL: https://seyfarth.visionmakegpt.work
# ============================================================
# ACHTUNG: Diese Datei als .env.prod speichern und echte Werte eintragen!
# Niemals committen!
# ============================================================

NODE_ENV=production
IMAGE_TAG=latest

# Database — STRONG password!
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here

# Medusa Secrets — generieren mit: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32_output
COOKIE_SECRET=CHANGE_ME_openssl_rand_hex_32_output_different

# URLs — Prod
MEDUSA_BACKEND_URL=https://seyfarth.visionmakegpt.work
SITE_URL=https://seyfarth.visionmakegpt.work
MAIN_WEBSITE_URL=https://www.containerdienst-seyfarth.de

# CORS — Prod
STORE_CORS=https://seyfarth.visionmakegpt.work
ADMIN_CORS=https://seyfarth.visionmakegpt.work
AUTH_CORS=https://seyfarth.visionmakegpt.work

# Publishable Key (nach erstem Start aus Admin Panel holen)
MEDUSA_PUBLISHABLE_KEY=pk_REPLACE_AFTER_FIRST_RUN

# SMTP — Brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your-brevo-api-key
SMTP_FROM=noreply@seyfarth-container.de
SMTP_FROM_NAME=Seyfarth Container-Dienst
OPERATOR_EMAIL=info@seyfarth-container.de
